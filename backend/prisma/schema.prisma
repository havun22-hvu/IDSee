generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  role              String   @default("BUYER") // BUYER, BREEDER, VET, CHIPPER, ADMIN

  // Email verification
  emailVerified     Boolean  @default(false)
  emailVerifyToken  String?
  emailVerifyExpires DateTime?

  // Professional info
  professionalId    String?  // Diergeneeskunderegister, UBN, RVO nummer
  professionalType  String?  // Type registratie
  verificationStatus String  @default("PENDING") // PENDING, VERIFIED, REJECTED

  // Peer verification
  verifiedById      String?  // Who verified this user
  verifiedAt        DateTime?
  verificationBond  Int      @default(0) // Credits staked as bond

  // Credits
  credits           Int      @default(0)
  lockedCredits     Int      @default(0) // Credits locked as verification bonds

  // Reputation
  warningCount      Int      @default(0)
  isSuspended       Boolean  @default(false)

  // Fraud cascade (B-track fase 3)
  fraudStatus       String   @default("LEREN") // LEREN, ORANJE, ROOD, BLOKKADE
  lastFraudAssessment DateTime?

  // Notitie-/kaartensysteem op de professional (PROPOSITION.md §4)
  cardStatus        String   @default("GEEN") // GEEN, GEEL, ROOD
  lastCardAssessment DateTime?

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  registrations     Registration[]
  creditTransactions CreditTransaction[]
  verificationsGiven PeerVerification[] @relation("Verifier")
  verificationsReceived PeerVerification[] @relation("Verified")
  fraudReported     FraudReport[] @relation("Reporter")
  fraudConfirmed    FraudReport[] @relation("Confirmer")
  fraudAgainst      FraudReport[] @relation("Subject")
  notesReceived     ProfessionalNote[] @relation("NoteSubject")
  notesCreated      ProfessionalNote[] @relation("NoteAuthor")
  importsRecorded   ImportRecord[] @relation("ImportRecorder")
}

model Animal {
  id              String    @id @default(uuid())
  chipIdHash      String    @unique  // Hashed chip ID for privacy
  species         String    // dog, cat, etc.
  breed           String?
  birthDate       DateTime?

  // Links
  motherChipHash  String?   // Link to mother

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  registrations   Registration[]
  importRecord    ImportRecord?
}

model Registration {
  id              String   @id @default(uuid())

  // Links
  userId          String   // Professional who registered
  user            User     @relation(fields: [userId], references: [id])
  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id])

  // Breeder confirmation (double confirmation)
  breederUbn      String?  // UBN of breeder to confirm
  breederUserId   String?  // Breeder user if registered
  breederConfirmed Boolean @default(false)
  breederConfirmedAt DateTime?
  breederRejectedReason String?

  // Blockchain
  dataHash        String   // Hash of registration data
  txHash          String?  // Cardano transaction hash
  status          String   @default("PENDING") // PENDING, CONFIRMED, DISPUTED, CANCELLED

  // Timestamps
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
}

model CreditTransaction {
  id              String   @id @default(uuid())

  // Links
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  // Transaction
  amount          Int      // Positive = add, negative = subtract
  type            String   // PURCHASE, USAGE, REFUND

  // Payment info (for purchases)
  paymentId       String?  // Mollie payment ID

  // Notes
  description     String?

  // Timestamps
  createdAt       DateTime @default(now())
}

model Nest {
  id              String   @id @default(uuid())

  // Breeder
  breederUserId   String

  // Parents
  motherChipHash  String
  fatherChipHash  String?

  // Nest info
  breed           String
  birthDate       DateTime
  puppyCount      Int

  // Blockchain
  dataHash        String
  txHash          String?
  status          String   @default("PENDING") // PENDING, CONFIRMED, FAILED

  // Timestamps
  createdAt       DateTime @default(now())
}

// Peer verification system - professionals verify each other
model PeerVerification {
  id              String   @id @default(uuid())

  // Verifier (existing professional)
  verifierId      String
  verifier        User     @relation("Verifier", fields: [verifierId], references: [id])

  // Verified (new professional)
  verifiedId      String
  verified        User     @relation("Verified", fields: [verifiedId], references: [id])

  // Bond
  bondAmount      Int      // Credits staked as guarantee
  bondLockedUntil DateTime // When bond can be released
  bondStatus      String   @default("LOCKED") // LOCKED, RELEASED, FORFEITED

  // Status
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, REVOKED

  // Timestamps
  createdAt       DateTime @default(now())
  releasedAt      DateTime?
}

// Buyer pay-per-check transaction (PROPOSITION.md §6). The score is only
// released after payment. Chip stored as hash for privacy (AVG §5).
model CheckTransaction {
  id                String   @id @default(uuid())
  sessionId         String   @unique
  chipIdHash        String   // hashed chip for score lookup (no plaintext)
  amount            Int      // cents, e.g. 200 for €2
  currency          String   @default("EUR")
  status            String   @default("PENDING") // PENDING, PAID, FAILED
  provider          String   @default("demo")
  providerPaymentId String?
  checkoutUrl       String?  // present for real redirect-based providers
  scoreShown        Boolean  @default(false)
  createdAt         DateTime @default(now())
  paidAt            DateTime?
}

// Fraud signals — only a verified vet can confirm; confirmed signals drive
// the graduated reputation cascade (PROPOSITION.md §4).
model FraudReport {
  id              String   @id @default(uuid())

  // Who reported. Null for anonymous buyer signals (source = BUYER).
  reporterId      String?
  reporter        User?    @relation("Reporter", fields: [reporterId], references: [id])
  source          String   @default("PROFESSIONAL") // PROFESSIONAL, BUYER

  // The professional the signal is about (the "person" of the cascade)
  subjectUserId   String
  subject         User     @relation("Subject", fields: [subjectUserId], references: [id])

  // Optional: the specific animal/registration that triggered it
  animalId        String?

  type            String   // e.g. omgekat_paspoort, ontbrekende_schakel, dubbele_registratie
  description     String

  // Onderscheid feit vs. signaal (PROPOSITION.md §9). A SIGNAAL is a suspected
  // irregularity that, once vet-confirmed, escalates the fraud cascade. A FEIT
  // is a neutral, verified observation (e.g. a legal passport conversion) — it
  // is recorded but NEVER counts as an accusation and does not cascade. The vet
  // sets this at confirmation time.
  category        String   @default("SIGNAAL") // SIGNAAL, FEIT

  // PENDING_VET_REVIEW, CONFIRMED, REJECTED
  status          String   @default("PENDING_VET_REVIEW")
  confirmedById   String?  // The verified vet who confirmed/rejected
  confirmer       User?    @relation("Confirmer", fields: [confirmedById], references: [id])
  reviewNote      String?
  confirmationDate DateTime?

  // Co-subject: the professional who stamped the betwiste schakel as "akkoord"
  // (PROPOSITION.md §4). Populated when the chain link was vet-checked; the
  // melder is never a subject. Dual-flag logic lands with the UBN-holder link.
  coSubjectProfessionalId String?

  // Open/herstel (PROPOSITION.md §4): a confirmed discrepancy is OPEN until an
  // arts/chipper resolves it (data corrected, chain closed). Only OPEN, confirmed
  // SIGNALS count toward the cascade — a resolved one no longer does.
  resolvedAt      DateTime?
  resolvedById    String?  // the arts/chipper who corrected it (never the owner)

  createdAt       DateTime @default(now())
}

// The IMPORT chain link (PROPOSITION.md §3a). A legally imported pup has no
// NL-moeder; the chain is closed instead by a verified NL-vet who physically
// checks the import papers and records the traceable foreign origin. A complete,
// traceable import yields the buyer a 🔵 "Geverifieerde import" label — its own
// label, NOT a downgrade on the NL green/orange/red scale.
model ImportRecord {
  id                  String   @id @default(uuid())

  animalId            String   @unique
  animal              Animal   @relation(fields: [animalId], references: [id])

  // The verified NL-vet who recorded the import
  recordedById        String
  recordedBy          User     @relation("ImportRecorder", fields: [recordedById], references: [id])

  countryOfOrigin     String   // land van herkomst
  foreignOriginId     String?  // buitenlandse fokker-/herkomst-identifier (traceerbaarheid)
  euPassportNumber    String?
  passportConverted   Boolean  @default(false) // is het EU-paspoort omgezet?
  vetCheckedDocuments Boolean  @default(false) // arts zag de invoerpapieren fysiek

  status              String   @default("CONFIRMED") // PENDING, CONFIRMED

  createdAt           DateTime @default(now())
}

// A verified discrepancy recorded against a professional (PROPOSITION.md §4).
// Created only AFTER verification by an admin or a verified vet — never on a
// bare buyer complaint. Note count drives the professional's card status, part
// of the same cascade as FraudReport.
model ProfessionalNote {
  id            String   @id @default(uuid())

  // The professional the note is about
  subjectUserId String
  subject       User     @relation("NoteSubject", fields: [subjectUserId], references: [id])

  // The admin/verified vet who verified the discrepancy
  createdById   String
  createdBy     User     @relation("NoteAuthor", fields: [createdById], references: [id])

  type          String   // e.g. chip_mismatch, ubn_mismatch
  description   String

  createdAt     DateTime @default(now())
}

// Configurable parameters (cascade thresholds etc.); service falls back to
// code defaults when a key is absent.
model SystemConfig {
  key   String @id
  value String
}

// Verification requests - pending verification requests
model VerificationRequest {
  id              String   @id @default(uuid())

  // Requester
  userId          String   @unique

  // Professional info submitted
  professionalId  String
  professionalType String  // UBN, DIERGENEESKUNDE, RVO_CHIPPER

  // Verification
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedById    String?  // Who reviewed (peer or admin)
  reviewNote      String?

  // Timestamps
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?
}
