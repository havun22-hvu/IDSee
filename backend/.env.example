# Database (SQLite - geen configuratie nodig, bestand wordt aangemaakt in prisma/dev.db)

# JWT
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# Cardano (optioneel - zonder deze draait de app in demo mode)
CARDANO_NETWORK="Preview"
BLOCKFROST_KEY="your_blockfrost_api_key"
WALLET_SEED="your 24 word seed phrase here never commit this"

# Server
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Payments
# Zonder PAYMENT_PROVIDER draait de €2-check in demo mode (direct "betaald").
# Zet op "mollie" + vul MOLLIE_API_KEY om echte iDEAL/creditcard te activeren.
PAYMENT_PROVIDER="demo"
MOLLIE_API_KEY="test_xxxxxxxxxxxx"
# Publieke backend-URL voor de Mollie webhook (alleen nodig bij echte Mollie)
BACKEND_URL="https://api.idsee.app"

# Email (zonder EMAIL_PROVIDER worden mails naar de console gelogd - demo)
# Zet op "smtp" + vul SMTP_* om echte e-mail te versturen.
EMAIL_PROVIDER="demo"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="postbus@idsee.app"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="IDSee <noreply@idsee.app>"
